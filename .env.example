# ============================================================
# Pharma DR · Environment Configuration
# Copy to .env and fill in real values
# NEVER commit .env to version control
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=pharma_dr
POSTGRES_USER=pharma_admin
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_SCHEMA_DW=dw
POSTGRES_SCHEMA_STAGING=staging
POSTGRES_SCHEMA_MART=mart

# ── PgBouncer ────────────────────────────────────────────────
PGBOUNCER_HOST=pgbouncer
PGBOUNCER_PORT=6432
PGBOUNCER_POOL_SIZE=20
PGBOUNCER_MAX_CLIENT_CONN=200

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password

# ── Apache Superset ──────────────────────────────────────────
SUPERSET_SECRET_KEY=CHANGE_ME_very_long_random_secret_key_here_min_42_chars
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=CHANGE_ME_admin_password
SUPERSET_ADMIN_EMAIL=admin@pharmadr.com
SUPERSET_PORT=8088

# ── SAP HANA (Incremental Extraction) ───────────────────────
SAP_HANA_HOST=your-hana-host.company.com
SAP_HANA_PORT=30015
SAP_HANA_USER=PHARMA_ETL_USER
SAP_HANA_PASSWORD=CHANGE_ME_hana_password
SAP_HANA_SCHEMA=SALES_SCHEMA
SAP_HANA_TABLE_SALES=VBAP_ENRICHED
SAP_HANA_TABLE_CLIENTS=KNA1_DR
SAP_HANA_TABLE_PRODUCTS=MARA_DR
# Watermark: timestamp column used for incremental extraction
SAP_HANA_WATERMARK_COL=_CHANGED_AT
SAP_HANA_BATCH_SIZE=5000

# ── SQL Server (Historical Migration) ───────────────────────
SQLSRV_HOST=your-sqlserver.company.com
SQLSRV_PORT=1433
SQLSRV_DB=HistoricalSales
SQLSRV_USER=etl_reader
SQLSRV_PASSWORD=CHANGE_ME_sqlsrv_password
SQLSRV_DRIVER={ODBC Driver 18 for SQL Server}

# ── Excel Distributor Feeds ──────────────────────────────────
# Local or Azure Blob path where Excel files land
EXCEL_LANDING_PATH=/app/data/excel_samples
EXCEL_PROCESSED_PATH=/app/data/excel_processed
EXCEL_REJECTED_PATH=/app/data/excel_rejected

# Azure Blob (optional, for cloud landing zone)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;...
AZURE_BLOB_CONTAINER_EXCEL=raw-excel-feeds

# ── ETL Settings ─────────────────────────────────────────────
ETL_LOG_LEVEL=INFO
ETL_LOG_PATH=/app/data/logs
ETL_WATERMARK_PATH=/app/data/watermarks
ETL_MAX_RETRY=3
ETL_RETRY_DELAY_SECONDS=30

# ── Notification (Email alerts on ETL failure) ──────────────
SMTP_HOST=smtp.company.com
SMTP_PORT=587
SMTP_USER=etl-alerts@company.com
SMTP_PASSWORD=CHANGE_ME_smtp_password
ALERT_RECIPIENTS=data-team@company.com,manager@company.com

# ── Environment ──────────────────────────────────────────────
ENVIRONMENT=development
# Options: development | staging | production
